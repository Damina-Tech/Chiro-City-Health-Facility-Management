// Chiro City Health Facilities & HR Management System
// Prisma schema - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ RBAC ============
model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ============ Facilities ============
// Status: DRAFT | SUBMITTED | APPROVED | ACTIVE | INACTIVE | SUSPENDED | TERMINATED
model Facility {
  id             String    @id @default(uuid())
  name           String
  type           String // HOSPITAL | CLINIC | HEALTH_CENTER | PHARMACY
  registrationNo String?
  licenseNo      String?
  licenseExpiry  DateTime?
  address        String?
  phone          String?
  email          String?
  status         String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, ACTIVE, INACTIVE, SUSPENDED, TERMINATED
  services       String? // JSON array of service names
  legalInfo      String? // JSON for legal details
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  staff        StaffAssignment[]
  staffMembers Staff[] // Staff with facilityId = this facility
  documents    FacilityDocument[]
  auditLogs    AuditLog[]         @relation("FacilityAudit")

  @@map("facilities")
}

model FacilityDocument {
  id         String   @id @default(uuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  name       String
  type       String // license, registration, contract, etc.
  filePath   String
  mimeType   String
  sizeBytes  Int?
  uploadedAt DateTime @default(now())
  uploadedBy String?

  @@map("facility_documents")
}

// ============ Staff ============
// Status: DRAFT | SUBMITTED | APPROVED | ACTIVE | INACTIVE | SUSPENDED | TERMINATED
model Staff {
  id               String    @id @default(uuid())
  employeeId       String    @unique
  name             String
  email            String
  phone            String?
  department       String?
  designation      String
  facilityId       String?
  facility         Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  departmentName   String?
  licenseNo        String?
  licenseExpiry    DateTime?
  status           String    @default("DRAFT")
  joiningDate      DateTime?
  address          String?
  emergencyContact String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignments StaffAssignment[]
  documents   StaffDocument[]
  auditLogs   AuditLog[]        @relation("StaffAudit")

  @@map("staff")
}

model StaffAssignment {
  id         String   @id @default(uuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  department String?
  assignedAt DateTime @default(now())
  assignedBy String?

  @@unique([staffId, facilityId])
  @@map("staff_assignments")
}

model StaffDocument {
  id         String   @id @default(uuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  name       String
  type       String
  filePath   String
  mimeType   String
  sizeBytes  Int?
  uploadedAt DateTime @default(now())
  uploadedBy String?

  @@map("staff_documents")
}

// ============ Notifications ============
model Notification {
  id        String    @id @default(uuid())
  type      String // LICENSE_EXPIRY | STAFF_ASSIGNMENT | FACILITY_ACTIVATION | etc.
  title     String
  message   String
  channel   String // EMAIL | SMS
  recipient String?
  sentAt    DateTime?
  readAt    DateTime?
  metadata  String? // JSON
  createdAt DateTime  @default(now())

  @@map("notifications")
}

// ============ Audit ============
model AuditLog {
  id         String    @id @default(uuid())
  action     String
  entity     String // Facility | Staff | User | etc.
  entityId   String?
  facilityId String?
  facility   Facility? @relation("FacilityAudit", fields: [facilityId], references: [id], onDelete: SetNull)
  staffId    String?
  staff      Staff?    @relation("StaffAudit", fields: [staffId], references: [id], onDelete: SetNull)
  userId     String?
  payload    String? // JSON
  createdAt  DateTime  @default(now())

  @@map("audit_logs")
}
