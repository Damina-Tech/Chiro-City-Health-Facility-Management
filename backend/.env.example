DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/chiro_health?schema=public"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=3001

# RBAC: Roles and permissions are stored in the database and seeded via prisma/seed.
# JWT payload includes the user's permissions array; guards enforce permission checks.
# Run `npx prisma db seed` after migrations to create Admin (all permissions) and Officer (subset) roles.
