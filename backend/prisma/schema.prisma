// Chiro City Health Facilities & HR Management System
// Prisma schema - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ RBAC ============
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notificationRecipients NotificationRecipient[]

  @@map("users")
}

// ============ Facilities ============
// Status: PENDING | APPROVED | ACTIVE | SUSPENDED (and legacy DRAFT | SUBMITTED | etc.)
model Facility {
  id                    String   @id @default(uuid())
  name                  String
  type                  String   // HOSPITAL | CLINIC | HEALTH_CENTER | PHARMACY | LAB
  ownershipType         String?  // PUBLIC | PRIVATE | NGO | CHARITY
  registrationNo        String?
  tin                   String?  // Tax Identification Number
  description           String?
  // Location
  region                String?
  city                  String?
  woreda                String?
  kebele                String?
  streetAddress         String?
  gpsLat                Float?
  gpsLng                Float?
  // Contact
  phone                 String?
  altPhone              String?
  email                 String?
  website               String?
  // Legal & compliance
  licenseNo             String?  // Health Operation License Number
  licenseIssueDate      DateTime?
  licenseExpiry         DateTime?
  regulatoryAuthority   String?
  accreditationLevel    String?
  // Operational
  operatingHours        String?  // e.g. "08:00-18:00" or JSON
  status                String   @default("DRAFT") // PENDING | APPROVED | ACTIVE | SUSPENDED | DRAFT | SUBMITTED | INACTIVE | TERMINATED
  approvalStatus        String?  // optional separate approval tracking
  // Legacy / extras
  address               String?  // kept for backward compatibility
  services              String?  // JSON array of service names
  legalInfo             String?  // JSON for legal details
  // Facility-type-specific (Hospital, Clinic, Health Center, Pharmacy) stored as JSON
  specificFields        String?  // JSON: HospitalSpecific | ClinicSpecific | HealthCenterSpecific | PharmacySpecific
  createdBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  staff           StaffAssignment[]
  staffMembers    Staff[]           // Staff with facilityId = this facility
  documents       FacilityDocument[]
  auditLogs       AuditLog[]        @relation("FacilityAudit")

  @@map("facilities")
}

model FacilityDocument {
  id         String   @id @default(uuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  name       String
  type       String   // license, registration, contract, etc.
  filePath   String
  mimeType   String
  sizeBytes  Int?
  uploadedAt DateTime @default(now())
  uploadedBy String?

  @@map("facility_documents")
}

// ============ Staff ============
// Status: DRAFT | ACTIVE | SUSPENDED | TERMINATED | etc.
model Staff {
  id            String   @id @default(uuid())
  employeeId    String   @unique // Staff ID
  name          String   // Full display name (derived from first + last when registering)
  firstName     String?
  lastName      String?
  gender        String?  // MALE | FEMALE | OTHER
  dateOfBirth   DateTime?
  nationalId    String?
  email         String
  phone         String?
  address       String?
  department    String?
  designation   String   // Job title / role label
  staffRole     String?  // DOCTOR | NURSE | PHARMACIST | LAB_TECH | ADMIN
  employmentType String? // PERMANENT | CONTRACT | TEMPORARY
  facilityId    String?
  facility      Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  departmentName String?
  licenseNo     String?
  licenseIssueDate DateTime?
  licenseExpiry DateTime?
  status        String   @default("DRAFT")
  joiningDate   DateTime?
  emergencyContact String?
  specificFields String? // JSON: doctor | nurse | pharmacist | labTechnician | administrative
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignments   StaffAssignment[]
  documents     StaffDocument[]
  auditLogs     AuditLog[]      @relation("StaffAudit")

  @@map("staff")
}

model StaffAssignment {
  id         String   @id @default(uuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  department String?
  assignedAt DateTime @default(now())
  assignedBy String?

  @@unique([staffId, facilityId])
  @@map("staff_assignments")
}

model StaffDocument {
  id         String   @id @default(uuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  name       String
  type       String
  filePath   String
  mimeType   String
  sizeBytes  Int?
  uploadedAt DateTime @default(now())
  uploadedBy String?

  @@map("staff_documents")
}

// ============ Notifications ============
model Notification {
  id        String   @id @default(uuid())
  type      String   // LICENSE_EXPIRY | STAFF_ASSIGNMENT | FACILITY_ACTIVATION | etc.
  title     String
  message   String
  channel   String   // EMAIL | SMS
  recipient String?
  sentAt    DateTime?
  readAt    DateTime?
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  recipients NotificationRecipient[]

  @@map("notifications")
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  userId         String
  deliveredAt    DateTime     @default(now())
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@map("notification_recipients")
}

// ============ Audit ============
model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entity     String   // Facility | Staff | User | etc.
  entityId   String?
  facilityId String?
  facility   Facility? @relation("FacilityAudit", fields: [facilityId], references: [id], onDelete: SetNull)
  staffId    String?
  staff      Staff?   @relation("StaffAudit", fields: [staffId], references: [id], onDelete: SetNull)
  userId     String?
  payload    String?  // JSON
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
